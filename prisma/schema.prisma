generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model LotteryGame {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  mainMin     Int      @default(1)
  mainMax     Int
  mainCount   Int
  bonusMin    Int?
  bonusMax    Int?
  bonusCount  Int      @default(0)
  hasBonus    Boolean  @default(false)
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  historicalDraws HistoricalDraw[]
  generationHistory GenerationHistory[]
}

model HistoricalDraw {
  id            String   @id @default(cuid())
  lotteryGameId String
  lotteryGame   LotteryGame @relation(fields: [lotteryGameId], references: [id], onDelete: Cascade)
  drawDate      DateTime
  mainNumbers   String   // Store as JSON string like "[1,2,3,4,5,6]"
  bonusNumbers  String   // Store as JSON string like "[7,8]"
  createdAt     DateTime @default(now())
  
  @@unique([lotteryGameId, drawDate])
}

model GenerationHistory {
  id          String   @id @default(cuid())
  lotteryGameId String
  lotteryGame   LotteryGame @relation(fields: [lotteryGameId], references: [id], onDelete: Cascade)
  strategyUsed String
  generatedNumbers String  // Store as JSON string
  createdAt   DateTime @default(now())
}